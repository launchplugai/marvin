# Marvin System Tokens
# Copy this file to .env and fill in the values.
# On the VPS, these are loaded automatically from the vault.
# In a new chat session, source this file or set these env vars.

# Hostinger VPS API token (also named ANTHROPIC_API_KEY on the VPS)
# Used for: managing Docker containers, checking logs, deploying projects
HOSTINGER_API_TOKEN=

# GitHub Personal Access Token
# Used for: cloning private repos (launchplugai/*)
GH_TOKEN=

# VM ID on Hostinger (don't change unless the VPS is recreated)
HOSTINGER_VM_ID=1405440

# API base URL
HOSTINGER_API_BASE=https://developers.hostinger.com/api/vps/v1


# Remote control API bearer token for the control-plane endpoint
CONTROL_API_TOKEN=

# Codex command used by the codex-brain worker (default: codex)
CODEX_COMMAND=codex
